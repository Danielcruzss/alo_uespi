generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum TipoManifestacao {
  RECLAMACAO
  DENUNCIA
  SUGESTAO
  SOLICITACAO
  ELOGIO
}

enum Prioridade {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

enum StatusManifestacao {
  RECEBIDA
  EM_ANALISE
  ENCAMINHADA
  RESPONDIDA
  FINALIZADA
}

model Usuario {
  id       Int      @id @default(autoincrement())
  nome     String   @db.VarChar(120)
  email    String   @unique @db.VarChar(180)
  senha    String   @db.VarChar(255)
  criadoEm DateTime @default(now()) @map("criado_em")

  manifestacoes Manifestacao[]

  @@map("usuarios")
}

model Setor {
  id       Int      @id @default(autoincrement())
  nome     String   @db.VarChar(120)
  email    String?  @db.VarChar(180)
  criadoEm DateTime @default(now()) @map("criado_em")

  manifestacoes Manifestacao[]

  @@map("setores")
}

model Manifestacao {
  id        Int              @id @default(autoincrement())
  protocolo String           @unique @db.VarChar(30)
  tipo      TipoManifestacao
  categoria String           @db.VarChar(100)
  titulo    String           @db.VarChar(160)
  descricao String           @db.Text
  anonima   Boolean          @default(true)

  nomeUsuario  String? @map("nome_usuario") @db.VarChar(120)
  emailUsuario String? @map("email_usuario") @db.VarChar(180)

  prioridade Prioridade         @default(MEDIA)
  status     StatusManifestacao @default(RECEBIDA)

  setorId Int?   @map("setor_id")
  setor   Setor? @relation(fields: [setorId], references: [id])

  usuarioId Int?     @map("usuario_id")
  usuario   Usuario? @relation(fields: [usuarioId], references: [id])

  resposta String? @db.Text

  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  @@map("manifestacoes")
}
